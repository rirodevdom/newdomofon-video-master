# NewDomofon Video Master production environment.
# Copy to /etc/newdomofon-video/app.env and replace every SET_LOCALLY value.
# Full reference: docs/ENVIRONMENT.md

# Node.js runtime mode.
NODE_ENV=production

# Local backend HTTP port behind Nginx.
BACKEND_PORT=3000

# Required PostgreSQL connection string. Set only on the server.
DATABASE_URL=SET_LOCALLY

# Required random JWT signing value, at least 32 characters.
JWT_SECRET=SET_LOCALLY

# Bootstrap/admin account.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=SET_LOCALLY

# Browser origin and reverse-proxy handling.
CORS_ORIGIN=https://video-master.example.com
TRUST_PROXY=true

# Maximum commands returned to a node in one poll.
NODE_COMMAND_POLL_LIMIT=20

# Canonical public URLs.
APP_PUBLIC_URL=https://video-master.example.com
SMARTYARD_PUBLIC_BASE_URL=https://video-master.example.com

# Legacy media base and strict-master local DVR fallback.
MEDIA_PUBLIC_BASE_URL=/api/media
DVR_ENGINE_URL=http://127.0.0.1:3010

# Lifetime of internal playback tokens, seconds.
PLAYBACK_TOKEN_TTL_SECONDS=900

# Required internal trusted-gateway value. Not a per-node media secret.
INTERNAL_DVR_SECRET=SET_LOCALLY

# Legacy self-registration. Keep disabled for operator-defined node credentials.
NODE_REGISTRATION_TOKEN=

# Master filesystem protection. Paths are separated with a colon.
MASTER_DISK_GUARD_PATHS=/:/var/lib/postgresql:/var/log/newdomofon-video
MASTER_DISK_MIN_FREE_BYTES=2147483648
MASTER_DISK_MIN_FREE_PERCENT=5
MASTER_DISK_RESUME_FREE_BYTES=4294967296
MASTER_DISK_RESUME_FREE_PERCENT=10
MASTER_DISK_MIN_FREE_INODES_PERCENT=5
MASTER_DISK_RESUME_FREE_INODES_PERCENT=8
MASTER_JOURNAL_MAX_SIZE=512M
MASTER_JOURNAL_MAX_AGE=7d
MASTER_DISK_STALE_TMP_MINUTES=60
MASTER_DISK_APT_CLEAN_ON_CRITICAL=true

# Automatic RTSP gateway / MediaMTX.
RTSP_GATEWAY_ENABLED=false
RTSP_PUBLIC_HOST=video-master.example.com
RTSP_PUBLIC_PORT=8554
RTSP_PUBLIC_URL_TEMPLATE=SET_BY_INSTALLER
RTSP_GATEWAY_SHARED_SECRET=SET_BY_INSTALLER
RTSP_RELAY_PUBLISH_SECRET=SET_BY_INSTALLER
RTSP_AUTO_OPEN_FIREWALL=true
RTSP_MEDIAMTX_VERSION=

# Event timeline defaults.
PUBLIC_EVENTS_INCLUDE_PASSIVE=false
ONVIF_EVENT_SUPPRESS_REPEATED_STATE=true
